{
  "expo": {
    "name": "oshilog",
    "slug": "oshilog-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "oshilog",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unetech.oshilog",
      "infoPlist": {
        "NSCameraUsageDescription": "プロフィール画像の撮影に使用します"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F9"
      },
      "package": "com.unetech.oshilog"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
